    const unsubEA = onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'expenses_ayam'), (snap) => setExpAyam(snap.docs.map(d => ({ id: d.id, ...d.data() })).sort((a,b) => new Date(a.date) - new Date(b.date))), handleSnapshotError);
